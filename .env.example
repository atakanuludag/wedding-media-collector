NEXT_PUBLIC_APP_TITLE="İsim & İsim Nişan"
NEXT_PUBLIC_THEME_COLOR="orange"
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Cloudflare Account ID — 32 karakterlik hex string (cfat_ ile BAŞLAMAZ)
# Dashboard: R2 → Overview veya URL: dash.cloudflare.com/<ACCOUNT_ID>/r2/overview
CLOUDFLARE_R2_ACCOUNT_ID="your_32_char_account_id"

# R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
CLOUDFLARE_R2_ACCESS_KEY_ID="your_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_secret_access_key"
CLOUDFLARE_R2_BUCKET_NAME="bucket-name"

# Opsiyonel: EU bucket için "ee", "eu", "weur" veya "eeur" (varsayılan: global endpoint)
CLOUDFLARE_R2_REGION="ee"

# Opsiyonel: özel endpoint (genelde gerekmez)
# CLOUDFLARE_R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
